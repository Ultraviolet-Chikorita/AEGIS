# Copy to .env and fill real values.
# Reasoning provider: bedrock | nvidia
REASONING_PROVIDER=bedrock

# AWS / Bedrock
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_SESSION_TOKEN=
BEDROCK_REASONING_MODEL_ID=mistral.mistral-large-2407-v1:0

# NVIDIA Serverless API (used when REASONING_PROVIDER=nvidia)
NVIDIA_API_KEY=your_nvidia_api_key
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_REASONING_MODEL_ID=mistralai/mistral-7b-instruct-v0.3

# ElevenLabs speech synthesis
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Neo4j Aura
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password

# Runtime
LOG_LEVEL=INFO
SIMULATION_TICK_HZ=10
VOICE_INPUT_MODEL=base
INTERFACE_MODE=web
WEB_HOST=127.0.0.1
WEB_PORT=8765
